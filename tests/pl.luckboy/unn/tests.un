    end
    
    function test_mlp_compute_derivative_computes_derivative_for_one_hidden_layer()
        shared::test_mlp_compute_derivative_computes_derivative_for_one_hidden_layer(mlp::class(dh, dloss), false)
    end

    function test_mlp_compute_derivative_computes_derivative_for_two_hidden_layers()
        shared::test_mlp_compute_derivative_computes_derivative_for_two_hidden_layers(mlp::class(dh, dloss), false)

uselib("unn")

module pl_luckboy_unn_tests
    tests()
    usemods("pl_luckboy_unn")
    usevars("pl_luckboy_unn")
    
    module shared
        usevars("pl_luckboy_unn")

        function test_mlp_compute_computes(class)
            ps = {
                Ns: .[ 256, 128 .]
                phis: .[.]
            }
            net = new(class, ps, se, xavier_init)
            X = [rand(); fill 256]
            compute(net, X, false)
        end

        function test_mlp_compute_computes_for_one_hidden_layer(class)
            ps = {
                Ns: .[ 256, 512, 128 .]
                phis: .[ sigmoid .]
            }
            net = new(class, ps, se, xavier_init)
            X = [rand(); fill 256]
            compute(net, X, false)
        end

        function test_mlp_compute_computes_for_two_hidden_layers(class)
            ps = {
                Ns: .[ 256, 512, 192, 128 .]
                phis: .[ sigmoid, tanh .]
            }
            net = new(class, ps, se, xavier_init)
            X = [rand(); fill 256]
            compute(net, X, false)
        end

        function test_mlp_compute_computes_for_two_hidden_layers_and_64_columns(class)
            ps = {
                Ns: .[ 256, 512, 192, 128 .]
                phis: .[ sigmoid, tanh .]
            }
            net = new(class, ps, se, xavier_init)
            X = [rand() fill 64; fill 256]
            compute(net, X, false)
        end

        function test_mlp_compute_derivative_computes_derivative(class, are_bs)
            ps = {
                Ns: .[ 256, 128 .]
                phis: .[.]
            }
            net = new(class, ps, se, xavier_init)
            X = [rand(); fill 256]
            Y = [rand(); fill 128]
            A = compute(net, X, true)
            dnet = compute_derivative(net, X, A[2], A[1], Y)
            asserteq(1, length(dnet.Ws))
            asserteq(256, columns(dnet.Ws[1]))
            asserteq(128, rows(dnet.Ws[1]))
            if are_bs
                asserteq(1, length(dnet.bs))
                asserteq(1, columns(dnet.bs[1]))
                asserteq(128, rows(dnet.bs[1]))
            end
        end

        function test_mlp_compute_derivative_computes_derivative_for_one_hidden_layer(class, are_bs)
            ps = {
                Ns: .[ 256, 512, 128 .]
                phis: .[ sigmoid .]
            }
            net = new(class, ps, se, xavier_init)
            X = [rand(); fill 256]
            Y = [rand(); fill 128]
            A = compute(net, X, true)
            dnet = compute_derivative(net, X, A[2], A[1], Y)
            asserteq(2, length(dnet.Ws))
            asserteq(256, columns(dnet.Ws[1]))
            asserteq(512, rows(dnet.Ws[1]))
            asserteq(512, columns(dnet.Ws[2]))
            asserteq(128, rows(dnet.Ws[2]))
            if are_bs
                asserteq(2, length(dnet.bs))
                asserteq(1, columns(dnet.bs[1]))
                asserteq(512, rows(dnet.bs[1]))
                asserteq(1, columns(dnet.bs[2]))
                asserteq(128, rows(dnet.bs[2]))
            end
        end

        function test_mlp_compute_derivative_computes_derivative_for_two_hidden_layers(class, are_bs)
            ps = {
                Ns: .[ 256, 512, 192, 128 .]
                phis: .[ sigmoid, tanh .]
            }
            net = new(class, ps, se, xavier_init)
            X = [rand(); fill 256]
            Y = [rand(); fill 128]
            A = compute(net, X, true)
            dnet = compute_derivative(net, X, A[2], A[1], Y)
            asserteq(3, length(dnet.Ws))
            asserteq(256, columns(dnet.Ws[1]))
            asserteq(512, rows(dnet.Ws[1]))
            asserteq(512, columns(dnet.Ws[2]))
            asserteq(192, rows(dnet.Ws[2]))
            asserteq(192, columns(dnet.Ws[3]))
            asserteq(128, rows(dnet.Ws[3]))
            if are_bs
                asserteq(3, length(dnet.bs))
                asserteq(1, columns(dnet.bs[1]))
                asserteq(512, rows(dnet.bs[1]))
                asserteq(1, columns(dnet.bs[2]))
                asserteq(192, rows(dnet.bs[2]))
                asserteq(1, columns(dnet.bs[3]))
                asserteq(128, rows(dnet.bs[3]))
            end
        end

        function test_mlp_compute_derivative_computes_derivative_for_two_hidden_layers_and_64_columns(class, are_bs)
            ps = {
                Ns: .[ 256, 512, 192, 128 .]
                phis: .[ sigmoid, tanh .]
            }
            net = new(class, ps, se, xavier_init)
            X = [rand() fill 64; fill 256]
            Y = [rand() fill 64; fill 128]
            A = compute(net, X, true)
            dnet = compute_derivative(net, X, A[2], A[1], Y)
            asserteq(3, length(dnet.Ws))
            asserteq(256, columns(dnet.Ws[1]))
            asserteq(512, rows(dnet.Ws[1]))
            asserteq(512, columns(dnet.Ws[2]))
            asserteq(192, rows(dnet.Ws[2]))
            asserteq(192, columns(dnet.Ws[3]))
            asserteq(128, rows(dnet.Ws[3]))
            if are_bs
                asserteq(3, length(dnet.bs))
                asserteq(1, columns(dnet.bs[1]))
                asserteq(512, rows(dnet.bs[1]))
                asserteq(1, columns(dnet.bs[2]))
                asserteq(192, rows(dnet.bs[2]))
                asserteq(1, columns(dnet.bs[3]))
                asserteq(128, rows(dnet.bs[3]))
            end
        end
    end

    function test_mlp_compute_computes()
        shared::test_mlp_compute_computes(mlp::class(dh, dloss))
    end


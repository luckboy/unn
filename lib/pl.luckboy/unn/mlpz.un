%% A MLP without biases for the swish function.
%%
%% The parameters of neural network creation for this MLP are:
%%
%% - `Ns` - the sizes of inputs of layers and the size of output of last layer
%% - `phis` - the activation functions
%%
%% The `Ns` length should be `length(phis) + 2`. This MLP uses inputs of activation functions
%% instead outputs of hidden layers for backpropagation.
module mlpz
    %% Computes outputs for the neural network.
    function compute(net, X, are_Zs)
        H = X
        if are_Zs
            Zs = .[.]
        end
        for i in 1 to length(net.phis)
            Z = net.Ws[i] * H
            H = net.phis[i](Z)
            if are_Zs
                push(Zs, Z)
            end
        end
        O = net.Ws[length(net.phis) + 1] * H
        if are_Zs
            .[ O, Zs .]
        else
            O
        end
    end

    %% Computes the partial derivatives of parameters of neural network by using backpropagation.
    function backpropagate(net, X, Zs, O, Y)
        dJ_dWs = .[.]
        dJ_dO = net.class.dloss(net.loss, O, Y)?
        if not isempty(net.phis)
            push(dJ_dWs, dJ_dO * net.phis[length(net.phis)](Zs[length(net.phis)])')
            dJ_dH = net.Ws[length(net.phis) + 1]' * dJ_dO
        else
            push(dJ_dWs, dJ_dO * X')
        end
        for i in length(net.phis) to 1 by -1
            dJ_dZ = dJ_dH .* net.class.dphi(net.phis[i], Zs[i])?
            if i > 1
                push(dJ_dWs, dJ_dZ * net.phis[i - 1](Zs[i - 1])')
                dJ_dH = net.Ws[i]' * dJ_dZ
            else
                push(dJ_dWs, dJ_dZ * X')
            end
        end
        reverse(dJ_dWs)
        {
            class: net.class
            phis: net.phis
            loss: net.loss
            Ws: dJ_dWs
        }
    end

    %% Creates a neural network.
    function new(class, ps, loss, init)
        Ws = .[.]
        for i in 1 to length(ps.Ns) - 1
            push(Ws, init(ps.Ns[i + 1], ps.Ns[i], ps.Ns[i], ps.Ns[i + 1], true))
        end
        {
            class: class
            phis: ps.phis
            loss: loss
            Ws: Ws
        }
    end

    %% Creates a neural network from other neural network.
    function renew(net, init)
        Ws = .[.]
        for i in 1 to length(net.Ws)
            push(Ws, init(rows(net.Ws[i]), columns(net.Ws[i]), columns(net.Ws[i]), rows(net.Ws[i]), true))
        end
        {
            class: net.class
            phis: net.phis
            loss: net.loss
            Ws: Ws
        }
    end
    
    %% Creates a class of neural network.
    %%
    %% The `dphi` argument and the `dloss` should be the [`dphi`](../pl_luckboy_unn.html#var.dphi)
    %% function and the the [`dloss`](../pl_luckboy_unn.html#var.dloss) function. An user can use
    %% own functions to calculation of derivatives.
    function class(dphi, dloss)
        {
            new: new
            renew: renew
            f: compute
            df: backpropagate
            dphi: dphi
            dloss: dloss
        }
    end
end

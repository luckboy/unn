module pl_luckboy_unn
    runwithdoc("mlp.un")
    runwithdoc("mlpwb.un")
    
    function se(O, Y)
        D = O .- Y
        E = D .* D ./ 2.0
        matrixarray((E * ones(columns(E), 1))' * ones(rows(E), 1))[1][1]
    end
    
    function cel(O, Y)
        L = .- Y .* log(O)
        matrixarray((L * ones(columns(L), 1))' * ones(rows(L), 1))[1][1]
    end
    
    function dh(f, H)
        if f == sigmoid
            H .* (1.0 .- H)
        else if f == tanh
            1.0 - H .* H
        else
            error("dh", "no derivative for function")
        end
    end

    function dloss(f, O, Y)
        if f == se
            O .- Y
        else if f == cel
            softmax(O) .- Y
        else
            error("dloss", "no derivative for function")
        end
    end
    
    function xavier_init(IN, ON)
        U = sqrt(6.0 / (IN + ON))
        (rand() * 2.0 - 1.0) * U
    end
    
    function zero_init(IN, ON)
        0.0
    end
    
    function new(class, ps, loss, f)
        class.new(class, ps, loss, f)
    end
    
    function renew(net, f)
        net.class.renew(net, f)
    end
    
    function compute(net, X, are_Hs)
        net.class.f(net, X, are_Hs)
    end
    
    function compute_derivative(net, X, Hs, O, Y)
        net.class.df(net, X, Hs, O, Y)
    end
    
    function mlp(Ns, phis, loss, f)
        ps = {
            Ns: Ns
            phis: phis
        }
        new(mlp::class(dh, dloss), ps, loss, f)
    end

    function mlpwb(Ns, phis, loss, f)
        ps = {
            Ns: Ns
            phis: phis
        }
        new(mlp::class(dh, dloss), ps, loss, f)
    end
    
    function next_minibatch(iter)
        if iter.has_next
            iter.has_next = false
            .[ iter.X, iter.Y .]
        else
            iter.has_next = true
            none
        end
    end
    
    function minibatch(X, Y)
        {
            f: next_minibatch
            X: X
            Y: Y
            has_next: true
        }
    end

    function next(iter)
        iter.f(iter)
    end
    
    function train(epochs, net, state, l, minibatch_iter, ps, alg, dir, is_printing, is_plotting)
        if net == none
            if dir != none
                net = (load(dir + pathsep + "net.bin")?)[1]
                state = (load(dir + pathsep + "state.bin")?)[1]
                l = (load(dir + pathsep + "loss.bin")?)[1]
                ps = (load(dir + pathsep + "params.bin")?)[1]
            else
                return error("train", "no directory")
            end
        else
            if dir != none
                save(dir + pathsep + "params.bin", ps)?
            end
        end
        if is_plotting
            chart = {}
        end
        for epoch in 1 to epochs
            t0 = clock()
            checkintr()
            N = 0
            loss = 0.0
            G = renew(net, zero_init)
            if is_printing
                println("Epoch: ", length(l) + 1)
                print("Computing gradient (", N,") ...\r")
                flush()?
            end
            while true
                checkintr()
                a = next(minibatch_iter)
                if a == none
                    break
                end
                X = a[1]
                Y = a[2]
                N = N + columns(X)
                a = compute(net, X, true)
                O = a[1]
                Hs = a[2]
                loss = loss + net.loss(O, Y)
                G = G .+ compute_derivative(net, X, Hs, O, Y)?
                if is_printing
                    print("Computing gradient (", N,") ...\r")
                    flush()?
                end
            end
            if is_printing
                println("Computing gradient (", N,") ... done")
            end
            G = G ./ N
            A = alg(net, ps, state, G)
            net = A[1]
            state = A[2]
            push(l, loss)
            t1 = clock()
            if dir != none
                save(dir + pathsep + "net.bin", net)?
                save(dir + pathsep + "state.bin", state)?
                save(dir + pathsep + "loss.bin", l)?
            end
            if is_printing
                println("Loss: ", loss)
                println("Time: ", formatmillis("hms", t1 - t0))
            end
            if is_plotting
                chart.x = .[ 0, length(l) - 1 .]
                chart.y = .[ min(l), max(l) .]
                chart.windowid = plot(chart, 0 to length(l) - 1, l, ",loss")?
            end
        end
        t0 = clock()
        checkintr()
        loss = 0.0
        if is_printing
            println("Result")
            print("Computing gradient (", N,") ...\r")
            flush()?
        end
        while true
            checkintr()
            a = next(minibatch_iter)
            if a == none
                break
            end
            X = a[1]
            Y = a[2]
            O = compute(net, X, false)
            loss = loss + net.loss(O, Y)
            if is_printing
                print("Computing gradient (", N,") ...\r")
                flush()?
            end
        end
        push(l, loss)
        if is_printing
            println("Computing gradient (", N,") ... done")
        end
        t1 = clock()
        if is_printing
            println("Loss: ", loss)
            println("Time: ", formatmillis("hms", t1 - t0))
        end
        if is_plotting
            chart.x = .[ 0, length(l) - 1 .]
            chart.y = .[ min(l), max(l) .]
            chart.windowid = plot(chart, 0 to length(l) - 1, l, ",loss")?
        end
        .[ net, state, l .]
    end
    
    function etrain(epochs, net, X, Y, ps, alg, dir, is_printing, is_plotting)
        a = train(epochs, net, none, .[.], minibatch(X, Y), ps, alg, dir, is_printing, is_plotting)?
        a[1]
    end

    runwithdoc("alg.un")
end
